    "#  NTILE() - split customers into quartiles by MonthlyCharges\n",
    "q10 = \"\"\"\n",
    "SELECT\n",
    "    customerID,\n",
    "    MonthlyCharges,\n",
    "    Churn,\n",
    "    NTILE(4) OVER (ORDER BY MonthlyCharges) as charge_quartile\n",
    "FROM customers\n",
    "\"\"\"\n",
    "result10 = pd.read_sql(q10, conn)\n",
    "print(result10.head(10))\n",
    "\n",
    "# Churn rate by quartile — combine with GROUP BY\n",
    "q10b = \"\"\"\n",
    "WITH quartiles AS (\n",
    "    SELECT\n",
    "        customerID,\n",
    "        MonthlyCharges,\n",
    "        Churn,\n",
    "        NTILE(4) OVER (ORDER BY MonthlyCharges) as charge_quartile\n",
    "    FROM customers\n",
    ")\n",
    "SELECT\n",
    "    charge_quartile,\n",
    "    COUNT(*) as total,\n",
    "    SUM(CASE WHEN Churn = 'Yes' THEN 1 ELSE 0 END) as churned,\n",
    "    ROUND(100.0 * SUM(CASE WHEN Churn = 'Yes' THEN 1 ELSE 0 END) / COUNT(*), 2) as churn_rate_pct\n",
    "FROM quartiles\n",
    "GROUP BY charge_quartile\n",
    "ORDER BY charge_quartile\n",
    "\"\"\"\n",
    "print(pd.read_sql(q10b, conn))\n",
    "\n"
   ]

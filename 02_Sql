    "# LAG() - compare each customer's charges to the \"previous\" one ordered by tenure\n",
    "q9 = \"\"\"\n",
    "SELECT\n",
    "    customerID,\n",
    "    tenure,\n",
    "    MonthlyCharges,\n",
    "    LAG(MonthlyCharges) OVER (ORDER BY tenure) as prev_customer_charge,\n",
    "    MonthlyCharges - LAG(MonthlyCharges) OVER (ORDER BY tenure) as charge_diff\n",
    "FROM customers\n",
    "ORDER BY tenure\n",
    "LIMIT 15\n",
    "\"\"\"\n",
    "print(pd.read_sql(q9, conn))\n"
   ]
